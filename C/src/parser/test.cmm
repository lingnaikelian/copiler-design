/* C-- Language Test Program */

int add(int a, int b) {
    return a + b;
}

float compute(float x, float y) {
    return x * y / 2.0;
}

int test_number_formats() {
    int dec = 123;
    int oct = 0123;
    int hex = 0xFF;
    int hex2 = 0x1A3;
    
    float f1 = 3.14;
    float f2 = 1.5e2;
    float f3 = 1.05e-4;
    float f4 = 2E10;
    
    return dec + oct + hex + hex2;
}

int main() {
    int result;
    float temp;
    
    result = add(10, 20);
    temp = compute(3.5, 2.0);
    
    if (result > 0) {
        result = result + 1;
    } else {
        result = 0;
    }
    
    while (temp < 100.0) {
        temp = temp * 1.5;
    }
    
    result = test_number_formats();
}
